# ============================================
# 環境變數範本 - 複製為 .env.local 後填入
# ============================================

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...your-service-role-key

# ── OpenAI (AI 配對) ──
OPENAI_API_KEY=sk-...your-openai-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=512

# ── Stripe (金流) ──
STRIPE_SECRET_KEY=sk_test_...your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_...your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...your-publishable-key
STRIPE_PRICE_PRO_MONTHLY=price_...your-pro-monthly-price-id
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...your-enterprise-monthly-price-id

# ── Resend (Email) ──
RESEND_API_KEY=re_...your-resend-key
RESEND_FROM_EMAIL=noreply@your-domain.com

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
